#include <stdio.h>
int main()
{
  int n, i,a=0,b=1,c;
  printf("Enter the limit\n");
  scanf("%d",&n);
  if (n==1)
    printf("%d ",a);
  else if (n==2)
     printf("%d %d ",a,b);
  else 
  { 
      printf("%d %d ",a,b);
      for (i=2;i<n;i++)
      { 
        c=a+b;
        a=b;
        b=c;
        if(c<=n)
        printf("%d ",c);
      }
    printf("\n");
  }
return 0;
}
