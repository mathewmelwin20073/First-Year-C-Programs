#include <stdio.h>
int fibonacci(int);
int main()
{
  int n, i;
  printf("Enter the limit\n");
  scanf("%d",&n);
   for (i=1;i<=n;i++)
  {
    int r= fibonacci(i);
    if(r<n)
    printf("%d ",r);
  }
return 0;
}
int fibonacci( int n)
{
  if (n==1)
  return 0;
  else if (n==2)
  return 1;
  else 
  return fibonacci(n-2)+ fibonacci(n-1);
}
