#include <stdio.h>
void main()
{
  char ch,s[100];
  int c=0,i;
  printf("Enter a string\n");
  gets(s);
  printf("Enter a character to find its occurence\n");
  scanf("%c",&ch);
  for(i=0; s[i]!='\0';i++)
  {
    if(s[i]==ch)
      c++;
  }
  if (c!=0)
  printf("%c occurs %d times \n",ch,c);
  else
    printf("Character not present\n");
}
  
