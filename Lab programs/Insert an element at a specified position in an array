#include <stdio.h>
int main()
{
  int a[100],n,i,pos,ne;
  printf("Enter the array size:\n");
  scanf("%d",&n);
  printf("Enter the elements:\n");
  for(i=0;i<n;i++)
  scanf("%d",&a[1]);
  printf("Enter the new element:\n");
  scanf("%d",&ne);
  printf("Enter the positiuon of new element:\n");
  scanf("%d",&pos);
  printf("\n The array before insertion:\n");
  for(i=0;i<n;i++)
  printf("%d ",a[i]);
  for(i=n-1;i>=pos-1;i--)
  a[i+1]=a[i];
  a[pos-1]=ne;
  printf("\n The array after insertion:\n");
  for(i=0;i<n;i++)
  printf("%d ",a[i]);
  printf("\n");
  return 0;
}




